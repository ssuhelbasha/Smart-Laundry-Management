<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top App Bar equivalent -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/primary"
            android:padding="16dp"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/btnMenuToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackground"
                android:backgroundTint="@color/white"
                android:tint="@color/white" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="Admin Operations"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- VIEW: Overview -->
        <ScrollView
            android:id="@+id/viewOverview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="30dp">

                <View
                    android:id="@+id/adminHeader"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/gradient_primary_header"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Analytics Metric Counters Row -->
                <LinearLayout
                    android:id="@+id/llMetrics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Card: Earnings -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Revenue"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvTotalRevenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Card: Bookings -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Orders"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvTotalOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Orders"
                                android:textColor="@color/accent"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Pricing management block -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPricingManager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:layout_constraintTop_toBottomOf="@id/llMetrics">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Global Price Adjustments"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Wash per Piece (₹)"
                                android:textColor="@color/text_primary"/>
                            <EditText
                                android:id="@+id/etBasePrice"
                                android:layout_width="80dp"
                                android:layout_height="40dp"
                                android:background="@drawable/edittext_rounded"
                                android:gravity="center"
                                android:hint="2.00"
                                android:inputType="numberDecimal"
                                android:text="2.00"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnUpdatePrice"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:text="Apply New Pricing"
                            android:background="@drawable/badge_bg"
                            app:backgroundTint="@color/primary"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

        <!-- VIEW: Manage Tasks -->
        <LinearLayout
            android:id="@+id/viewTasks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Platform Tasks"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAdminOrders"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- VIEW: User Directory -->
        <LinearLayout
            android:id="@+id/viewUsers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registered Users"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAdminUsers"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

    </LinearLayout>

    <!-- SIDEBAR (DRAWER) -->
    <LinearLayout
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingTop="40dp">

        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin Panel"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnNavOverview"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard Overview"
            android:gravity="start|center_vertical"
            android:paddingHorizontal="24dp"
            android:textColor="@color/text_primary"/>

        <Button
            android:id="@+id/btnNavTasks"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Tasks"
            android:gravity="start|center_vertical"
            android:paddingHorizontal="24dp"
            android:textColor="@color/text_primary"/>

        <Button
            android:id="@+id/btnNavUsers"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="User Directory"
            android:gravity="start|center_vertical"
            android:paddingHorizontal="24dp"
            android:textColor="@color/text_primary"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnLogout"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:gravity="start|center_vertical"
            android:paddingHorizontal="24dp"
            android:textColor="#FF5252"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
